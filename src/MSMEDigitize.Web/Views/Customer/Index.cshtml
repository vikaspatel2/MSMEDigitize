@model IEnumerable<MSMEDigitize.Core.Entities.Invoicing.Customer>
@{
    ViewData["Title"] = "Customers";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Customers</h5>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2">
            <input name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Name, phone, email..." style="width:240px">
            <button class="btn btn-sm btn-outline-secondary">Search</button>
        </form>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Add Customer</a>
    </div>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>GST</th>
                    <th>Outstanding</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td><div class="fw-semibold">@c.Name</div><div class="small text-muted">@c.ContactPerson</div></td>
                        <td class="small">@c.Phone</td>
                        <td class="small text-muted">@(c.GSTIN ?? "—")</td>
                        <td class="small @(c.OutstandingBalance > 0 ? "text-warning fw-semibold" : "text-muted")">₹@c.OutstandingBalance.ToString("N0")</td>
                        <td><span class="badge @(c.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">@(c.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-outline-primary"><i class="fas fa-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-outline-secondary"><i class="fas fa-edit"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>