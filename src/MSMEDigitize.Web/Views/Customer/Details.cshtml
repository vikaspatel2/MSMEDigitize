@model MSMEDigitize.Core.Entities.Invoicing.Customer
@{ ViewData["Title"] = Model.Name; Layout = "_Layout"; }

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">@Model.Name</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Customer">Customers</a></li>
            <li class="breadcrumb-item active">Details</li>
        </ol></nav>
    </div>
    <a href="/Customer/Edit/@Model.Id" class="btn btn-outline-primary"><i class="fas fa-edit me-1"></i>Edit</a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-3">Contact Info</h6>
                <p class="mb-1"><i class="fas fa-envelope me-2 text-muted"></i>@(Model.Email ?? "—")</p>
                <p class="mb-1"><i class="fas fa-phone me-2 text-muted"></i>@(Model.Phone ?? "—")</p>
                <p class="mb-1"><i class="fas fa-user me-2 text-muted"></i>@(Model.ContactPerson ?? "—")</p>
                <hr />
                <h6 class="text-muted text-uppercase small mb-2">GST / PAN</h6>
                <p class="mb-1 font-monospace small">@(Model.GSTIN ?? "—")</p>
                <p class="mb-0 font-monospace small">@(Model.PAN ?? "—")</p>
            </div>
        </div>
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body">
                <h6 class="text-muted text-uppercase small mb-3">Financials</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Outstanding</span>
                    <span class="fw-bold text-danger">₹@Model.OutstandingBalance.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Total Revenue</span>
                    <span class="fw-bold text-success">₹@Model.TotalRevenue.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Credit Limit</span>
                    <span class="fw-bold">₹@Model.CreditLimit.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                <h6 class="mb-0">Invoice History</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr><th class="ps-3">Invoice #</th><th>Date</th><th class="text-end">Amount</th><th class="text-center">Status</th></tr>
                    </thead>
                    <tbody>
                        @if (Model.Invoices?.Any() == true) {
                            @foreach (var inv in Model.Invoices.OrderByDescending(i => i.InvoiceDate).Take(20)) {
                            <tr>
                                <td class="ps-3"><a href="/Invoice/Details/@inv.Id">@inv.InvoiceNumber</a></td>
                                <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                                <td class="text-end fw-semibold">₹@inv.TotalAmount.ToString("N2")</td>
                                <td class="text-center">
                                    <span class="badge bg-@(inv.Status == MSMEDigitize.Core.Enums.InvoiceStatus.Paid ? "success" : inv.Status == MSMEDigitize.Core.Enums.InvoiceStatus.Overdue ? "danger" : "warning")-subtle text-@(inv.Status == MSMEDigitize.Core.Enums.InvoiceStatus.Paid ? "success" : inv.Status == MSMEDigitize.Core.Enums.InvoiceStatus.Overdue ? "danger" : "warning")">@inv.Status</span>
                                </td>
                            </tr>
                            }
                        } else {
                            <tr><td colspan="4" class="text-center py-4 text-muted">No invoices yet</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
