@using MSMEDigitize.Core.DTOs
@* @model PagedResult<MSMEDigitize.Core.Entities.Invoice>
 *@@{ ViewData["Title"] = "Invoices"; }
<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h5 class="fw-bold mb-1">Invoices</h5>
    <p class="text-muted small mb-0">@Model.TotalCount total invoices</p>
  </div>
  <div class="d-flex gap-2">
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>New Invoice</a>
    <a asp-controller="Reports" asp-action="ExportSalesExcel" class="btn btn-outline-success"><i class="fas fa-file-excel me-2"></i>Export</a>
  </div>
</div>
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-0">
    <form method="get" class="row g-2">
      <div class="col-md-4"><input name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Search invoice or customer..."></div>
      <div class="col-md-3">
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          @foreach(var s in Enum.GetValues<MSMEDigitize.Core.Enums.InvoiceStatus>()){
          <option value="@s" selected="@(s.ToString()==ViewBag.Status?.ToString())">@s</option>}
        </select>
      </div>
      <div class="col-auto"><button class="btn btn-sm btn-primary">Filter</button></div>
    </form>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light"><tr>
          <th class="small fw-semibold">Invoice #</th><th class="small fw-semibold">Customer</th>
          <th class="small fw-semibold">Date</th><th class="small fw-semibold">Due</th>
          <th class="small fw-semibold text-end">Amount</th><th class="small fw-semibold text-end">Balance</th>
          <th class="small fw-semibold">Status</th><th></th>
        </tr></thead>
        <tbody>
          @foreach(var inv in Model.Items){
          <tr>
            <td><a asp-action="Details" asp-route-id="@inv.Id" class="fw-semibold text-primary text-decoration-none">@inv.InvoiceNumber</a></td>
            <td class="small">@inv.Customer?.Name</td>
            <td class="small text-muted">@inv.InvoiceDate.ToString("dd MMM yy")</td>
            <td class="small @(inv.DueDate < DateTime.Today && inv.Status != MSMEDigitize.Core.Enums.InvoiceStatus.Paid ? "text-danger fw-semibold" : "text-muted")">@inv.DueDate.ToString("dd MMM yy")</td>
            <td class="text-end small fw-semibold">₹@inv.TotalAmount.ToString("N0")</td>
            <td class="text-end small @(inv.BalanceAmount > 0 ? "text-warning fw-semibold" : "text-success")">₹@inv.BalanceAmount.ToString("N0")</td>
            <td><span class="badge rounded-pill @(inv.Status == MSMEDigitize.Core.Enums.InvoiceStatus.Paid?"bg-success":inv.Status==MSMEDigitize.Core.Enums.InvoiceStatus.Overdue?"bg-danger":inv.Status==MSMEDigitize.Core.Enums.InvoiceStatus.Draft?"bg-secondary":"bg-warning text-dark")">@inv.Status</span></td>
            <td class="text-end">
              <div class="btn-group btn-group-sm">
                <a asp-action="Details" asp-route-id="@inv.Id" class="btn btn-outline-primary btn-sm"><i class="fas fa-eye"></i></a>
                <a asp-action="Download" asp-route-id="@inv.Id" class="btn btn-outline-secondary btn-sm"><i class="fas fa-download"></i></a>
              </div>
            </td>
          </tr>}
        </tbody>
      </table>
    </div>
  </div>
  @if(Model.TotalPages > 1){
  <div class="card-footer bg-white"><nav><ul class="pagination pagination-sm mb-0 justify-content-center">
    @for(int p=1;p<=Model.TotalPages;p++){
    <li class="page-item @(p==Model.PageNumber?"active":"")"><a class="page-link" asp-action="Index" asp-route-page="@p" asp-route-search="@ViewBag.Search">@p</a></li>}
  </ul></nav></div>}
</div>