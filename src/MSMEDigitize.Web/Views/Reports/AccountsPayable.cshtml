@model IEnumerable<MSMEDigitize.Core.Entities.Invoicing.Vendor>
@{ ViewData["Title"] = "Accounts Payable"; Layout = "_Layout"; }
<div class="page-header mb-4">
    <h1 class="h3 mb-0">Accounts Payable</h1>
    <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/Reports">Reports</a></li>
        <li class="breadcrumb-item active">Accounts Payable</li>
    </ol></nav>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr><th class="ps-4">Vendor</th><th>GSTIN</th><th class="text-end">Outstanding (₹)</th><th class="text-center">Payment Terms</th></tr>
            </thead>
            <tbody>
                @foreach(var v in Model ?? Enumerable.Empty<MSMEDigitize.Core.Entities.Invoicing.Vendor>()) {
                    <tr>
                        <td class="ps-4 fw-semibold">@v.Name</td>
                        <td class="font-monospace small">@(v.GSTIN ?? "—")</td>
                        <td class="text-end fw-bold text-danger">₹@v.CurrentOutstanding.ToString("N2")</td>
                        <td class="text-center">@v.PaymentTermsDays days</td>
                    </tr>
                }
                @if(!(Model?.Any() ?? false)){
                    <tr><td colspan="4" class="text-center py-4 text-muted">No outstanding payables</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
