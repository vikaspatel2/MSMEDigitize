@model IEnumerable<MSMEDigitize.Core.Entities.Inventory.Product>
@{ ViewData["Title"] = "Stock Status Report"; Layout = "_Layout"; }
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Stock Status Report</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Reports">Reports</a></li>
            <li class="breadcrumb-item active">Stock Status</li>
        </ol></nav>
    </div>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr><th class="ps-4">Product</th><th>SKU</th><th class="text-end">Current Stock</th><th class="text-end">Reorder Point</th><th class="text-center">Status</th></tr>
            </thead>
            <tbody>
                @foreach(var p in Model ?? Enumerable.Empty<MSMEDigitize.Core.Entities.Inventory.Product>()) {
                    var isLow = p.CurrentStock <= p.ReorderPoint;
                    <tr>
                        <td class="ps-4 fw-semibold">@p.Name</td>
                        <td class="font-monospace small">@(p.SKU ?? "—")</td>
                        <td class="text-end @(isLow?"text-danger fw-bold":"")">@p.CurrentStock @p.Unit</td>
                        <td class="text-end text-muted">@p.ReorderPoint</td>
                        <td class="text-center">
                            <span class="badge bg-@(isLow?"danger":"success")-subtle text-@(isLow?"danger":"success")">
                                @(isLow ? "Low Stock" : "OK")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
