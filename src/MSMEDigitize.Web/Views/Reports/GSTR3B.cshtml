@model object
@{ ViewData["Title"] = "GSTR-3B Summary"; Layout = "_Layout";
   int month = ViewBag.Month ?? DateTime.Now.Month;
   int year  = ViewBag.Year  ?? DateTime.Now.Year; }
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">GSTR-3B Summary</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Reports">Reports</a></li>
            <li class="breadcrumb-item active">GSTR-3B</li>
        </ol></nav>
    </div>
    <form method="get" class="d-flex gap-2">
        <select name="month" class="form-select form-select-sm" style="width:130px">
            @for(int m=1;m<=12;m++){<option value="@m" selected="@(m==month)">@(new DateTime(year,m,1).ToString("MMMM"))</option>}
        </select>
        <select name="year" class="form-select form-select-sm" style="width:90px">
            @for(int y=DateTime.Now.Year;y>=DateTime.Now.Year-3;y--){<option value="@y" selected="@(y==year)">@y</option>}
        </select>
        <button class="btn btn-sm btn-primary">View</button>
    </form>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body">
        @if(Model != null){
            <pre class="bg-light p-3 rounded small">@System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions{WriteIndented=true})</pre>
        } else {
            <p class="text-muted text-center py-4">No GST data for this period.</p>
        }
    </div>
</div>
