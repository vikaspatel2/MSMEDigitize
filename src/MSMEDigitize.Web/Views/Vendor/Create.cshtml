@model MSMEDigitize.Core.Entities.Invoicing.Vendor
@{ ViewData["Title"] = "Add Vendor"; Layout = "_Layout"; }

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Add Vendor</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/Vendor">Vendors</a></li>
            <li class="breadcrumb-item active">Add</li>
        </ol></nav>
    </div>
</div>

<div class="card border-0 shadow-sm" style="max-width:800px">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Vendor Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="Contact / Business name" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="vendor@example.com" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Phone</label>
                    <input asp-for="Phone" class="form-control" placeholder="10-digit mobile number" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">GSTIN</label>
                    <input asp-for="GSTIN" class="form-control font-monospace" placeholder="22AAAAA0000A1Z5" maxlength="15" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">PAN</label>
                    <input asp-for="PAN" class="form-control font-monospace" placeholder="AAAAA0000A" maxlength="10" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">TDS Rate (%)</label>
                    <input asp-for="TDSRate" type="number" step="0.01" class="form-control" value="0" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Address</label>
                    <input asp-for="Address" class="form-control" placeholder="Full address" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Payment Terms (days)</label>
                    <input asp-for="PaymentTermsDays" type="number" class="form-control" value="30" min="0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Bank Account No.</label>
                    <input asp-for="BankAccount" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">IFSC Code</label>
                    <input asp-for="IFSC" class="form-control font-monospace" placeholder="HDFC0001234" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">MSME Registration No.</label>
                    <input asp-for="MSMERegistrationNumber" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Vendor Category</label>
                    <input asp-for="VendorCategory" class="form-control" placeholder="Goods, Services, Both…" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i>Save Vendor</button>
                <a href="/Vendor" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
