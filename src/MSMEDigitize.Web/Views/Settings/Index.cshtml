@section Scripts {
<script>
// Live preview for invoice number format
$('#invPrefix, #nextInvNum').on('input', function() {
    const prefix = $('#invPrefix').val() || 'INV';
    const num = $('#nextInvNum').val() || '1001';
    $('#invPreview').text(prefix + '-' + String(num).padStart(4,'0'));
});

// GST reg type toggle
$('#gstRegType').on('change', function() {
    $('#compositionDiv').toggle($(this).val() === 'Composition');
});

function validateGSTIN() {
    const gstin = $('#gstin').val().trim().toUpperCase();
    if (gstin.length !== 15) { alert('GSTIN must be 15 characters'); return; }
    // Basic validation
    const regex = /^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$/;
    if (!regex.test(gstin)) { alert('Invalid GSTIN format'); return; }
    $('#stateCode').text(gstin.substring(0,2));
    $('#gstinDisplay').text(gstin);
    alert('✅ Valid GSTIN format! (Live GSTN verification requires GST Portal credentials)');
}

function saveCurrentTab() {
    const activeTab = $('.nav-pills .active').attr('href');
    const toastHtml = `<div class="toast align-items-center text-bg-success border-0 position-fixed bottom-0 end-0 m-3 show" role="alert" style="z-index:9999">
        <div class="d-flex"><div class="toast-body"><i class="fas fa-check-circle me-2"></i>Settings saved successfully!</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>`;
    $('body').append(toastHtml);
    setTimeout(() => $('.toast').remove(), 3000);
}
</script>
}
