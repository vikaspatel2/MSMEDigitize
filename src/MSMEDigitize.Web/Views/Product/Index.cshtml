@* @model IEnumerable<MSMEDigitize.Core.Entities.Product>
 *@@{
    ViewData["Title"] = "Products & Services";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">Products & Services</h5>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2">
            <input name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Name or SKU..." style="width:200px">
            <div class="form-check form-switch d-flex align-items-center ms-2">
                <input class="form-check-input" type="checkbox" name="lowStock" value="true" @(ViewBag.LowStock == true ? "checked" : "") id="lowStockChk">
                <label class="form-check-label small ms-2" for="lowStockChk">Low Stock Only</label>
            </div>
            <button class="btn btn-sm btn-outline-secondary">Filter</button>
        </form>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Add Product</a>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-xl-4 g-3">
    @foreach (var p in Model)
    {
        <div class="col">
            <div class="card border-0 shadow-sm h-100 @(p.CurrentStock <= p.ReorderPoint && p.TrackInventory ? "border-warning border-2" : "")">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        @* <span class="badge @(p.Type == MSMEDigitize.Core.Enums.ProductType.Services ? "bg-info-subtle text-info" : "bg-primary-subtle text-primary")">@p.Type</span> *@
                        @if (p.CurrentStock <= p.ReorderPoint && p.TrackInventory)
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle me-1"></i>Low</span>
                        }
                    </div>
                    <h6 class="fw-bold mb-1">@p.Name</h6>
                    <div class="small text-muted mb-2">
                        SKU: @(p.SKU ?? "—") | HSN: @(p.HSNCode ?? p.SACCode ?? "—")
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-bold text-primary">₹@p.SalePrice.ToString("N2")</div>
                            <div class="small text-muted">GST: @p.GSTRate%</div>
                        </div>
                        @if (p.TrackInventory)
                        {
                            <div class="text-end">
                                <div class="fw-bold @(p.CurrentStock <= p.ReorderPoint ? "text-danger" : "text-success")">@p.CurrentStock</div>
                                <div class="small text-muted">@p.Unit</div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 py-2">
                    <div class="btn-group btn-group-sm w-100">
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-secondary">Edit</a>
                        @if (p.TrackInventory)
                        {
                            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#stockModal" data-id="@p.Id" data-name="@p.Name" data-stock="@p.CurrentStock">Adjust Stock</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Stock Modal -->
<div class="modal fade" id="stockModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Adjust Stock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="StockAdjustment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="prodId" name="productId">
                <div class="modal-body">
                    <p class="text-muted small" id="prodInfo"></p>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Adjustment Quantity (+ add, - remove)</label>
                        <input name="qty" type="number" step="0.01" class="form-control" placeholder="+50 or -10" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Notes</label>
                        <input name="notes" class="form-control" placeholder="Reason for adjustment">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Adjust</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var stockModalEl = document.getElementById('stockModal');
        stockModalEl.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            if (button) {
                document.getElementById('prodId').value = button.getAttribute('data-id');
                document.getElementById('prodInfo').textContent = button.getAttribute('data-name') + " | Current: " + button.getAttribute('data-stock');
            }
        });
    </script>
}