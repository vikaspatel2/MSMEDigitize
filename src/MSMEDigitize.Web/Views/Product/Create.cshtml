@model MSMEDigitize.Core.Entities.Inventory.Product
@{ ViewData["Title"] = "Add Product"; Layout = "_Layout"; }

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">Add Product</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="/Product">Products</a></li>
            <li class="breadcrumb-item active">Add</li>
        </ol></nav>
    </div>
</div>

<div class="card border-0 shadow-sm" style="max-width:900px">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label fw-semibold">Product Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">SKU / Item Code</label>
                    <input asp-for="SKU" class="form-control font-monospace" placeholder="Auto-generated if blank" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId" class="form-select">
                        <option value="">— Select Category —</option>
                        @if (ViewBag.Categories != null) {
                            @foreach (var c in (IEnumerable<MSMEDigitize.Core.Entities.Inventory.ProductCategory>)ViewBag.Categories) {
                                <option value="@c.Id">@c.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Unit of Measure</label>
                    <input asp-for="Unit" class="form-control" placeholder="pcs, kg, ltr, box…" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">HSN Code</label>
                    <input asp-for="HSNCode" class="form-control font-monospace" placeholder="8-digit HSN" />
                </div>
                <div class="col-12"><hr class="my-1" /><p class="text-muted small mb-1">Pricing</p></div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Purchase Price (₹)</label>
                    <input asp-for="PurchasePrice" type="number" step="0.01" class="form-control" value="0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Selling Price (₹) <span class="text-danger">*</span></label>
                    <input asp-for="SellingPrice" type="number" step="0.01" class="form-control" value="0" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">MRP (₹)</label>
                    <input asp-for="MRP" type="number" step="0.01" class="form-control" value="0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">GST Rate (%)</label>
                    <select asp-for="GSTRate" class="form-select">
                        <option value="0">0% (Exempt)</option>
                        <option value="5">5%</option>
                        <option value="12" selected>12%</option>
                        <option value="18">18%</option>
                        <option value="28">28%</option>
                    </select>
                </div>
                <div class="col-12"><hr class="my-1" /><p class="text-muted small mb-1">Inventory</p></div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Opening Stock</label>
                    <input asp-for="CurrentStock" type="number" step="0.01" class="form-control" value="0" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Reorder Point</label>
                    <input asp-for="ReorderPoint" type="number" step="0.01" class="form-control" value="10" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Min Stock Level</label>
                    <input asp-for="MinStockLevel" type="number" step="0.01" class="form-control" value="5" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Max Stock Level</label>
                    <input asp-for="MaxStockLevel" type="number" step="0.01" class="form-control" value="1000" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-2"></i>Save Product</button>
                <a href="/Product" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
